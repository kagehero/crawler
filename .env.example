# MongoDB（必須）
#
# ローカル例:
# MONGODB_URI=mongodb://127.0.0.1:27017/crawler_jobs
#
# MongoDB Atlas（クラウド）例: ダッシュボードの「Connect」→「Drivers」で取得した URI。
# パスワードに @ : / ? # などが含まれる場合は URL エンコードが必要です。
#
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# 任意: DB 名（デフォルト: crawler_jobs）
# MONGODB_DB_NAME=crawler_jobs

# 管理画面ログイン・手動 CSV 取り込み API 用（必須・本番では長いランダム文字列）
ADMIN_SECRET=change-me-long-random-string

# 定期実行 GET /api/cron/import 用（未設定時は ADMIN_SECRET にフォールバック）
CRON_SECRET=change-me-cron-secret

# オプション: 取り込み CSV（cron 用）。未設定時はリポジトリルートから crawler/data/output.csv
# IMPORT_CSV_PATH=crawler/data/output.csv

# --- スクレイパー上書き（通常は不要。crawler/ はリポジトリ直下）---
# SCRAPER_ROOT=/path/to/crawler
# SCRAPER_PYTHON=/path/to/.venv/bin/python
# SCRAPER_INPUT=site_url_jobmedley_raks
# SCRAPER_OUTPUT=data/output.csv
# SCRAPER_OUTPUT_DIR=data/pages
